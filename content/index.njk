---
layout: false
permalink: /
---
{%- set totalGroups = 0 %}
{%- for cat in collections.categories %}
  {%- set totalGroups = totalGroups + cat.data.groupCount %}
{%- endfor %}
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/head.njk" %}
  <title>Vancouver Community Directory — {{ totalGroups }}+ Groups, Clubs & Meetups (2026)</title>
  <meta name="description" content="{{ site.description }}">
  <meta property="og:title" content="Vancouver Community Directory — Find Your People">
  <meta property="og:description" content="{{ site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}/">
  <meta property="og:image" content="{{ site.url }}/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Vancouver Community Directory — Find Your People">
  <meta name="twitter:description" content="{{ site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/og-image.png">
  <link rel="canonical" href="{{ site.url }}/">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}",
    "description": "{{ site.description }}",
    "areaServed": {
      "@type": "City",
      "name": "Vancouver",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "BC",
        "addressCountry": "CA"
      }
    },
    "publisher": {
      "@type": "Person",
      "name": "Patrick Bollenbach",
      "url": "https://bollenbach.ca"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Community Categories in Vancouver",
    "numberOfItems": {{ collections.categories.length }},
    "itemListElement": [
      {%- for cat in collections.categories %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ cat.data.title }}",
        "url": "{{ site.url }}/{{ cat.fileSlug }}/"{% if cat.data.groupCount %},
        "numberOfItems": {{ cat.data.groupCount }}{% endif %}
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
  </script>
</head>
<body class="homepage">
<a href="#main-content" class="skip-link">Skip to content</a>
<header class="site-header">
  <a href="/" class="logo">Vancouver Community</a>
  <button class="sidebar-toggle" aria-expanded="false" aria-controls="sidebar">Browse</button>
</header>
<div class="main-container">
{% set currentSlug = "" %}
{% include "partials/sidebar.njk" %}
<main class="content content-wide" id="main-content">
  <div class="homepage-hero">
    <div class="homepage-intro">
      <div class="homepage-intro-text">
        <h1 class="homepage-lede">Find your people in Vancouver.</h1>
        <p class="homepage-desc">{{ totalGroups }}+ groups across {{ collections.categories.length }} categories — run clubs, supper clubs, philosophy circles, maker spaces, and a lot more. Browse, click through, and show up.</p>
        <div class="homepage-actions">
          <a href="/submit/" class="homepage-action-primary" data-umami-event="click-submit-cta" data-umami-event-source="homepage">Know a group? Add it</a>
          <a href="#" class="surprise-btn" onclick="goRandom(); return false;" data-umami-event="click-surprise" data-umami-event-source="homepage">Surprise me &rarr;</a>
        </div>
        <div class="homepage-cards">
          <div class="homepage-newsletter">
            <p class="homepage-newsletter-heading">Get the Vancouver roundup</p>
            <p class="homepage-newsletter-desc">New groups, community events, and neighbourhood picks — delivered weekly.</p>
            <form class="newsletter-form" data-umami-event="newsletter-signup">
              <input type="email" class="newsletter-input" placeholder="your@email.com" required aria-label="Email address">
              <button type="submit" class="newsletter-btn">Subscribe</button>
            </form>
            <span class="newsletter-status"></span>
          </div>
          <div class="builder-card">
            <div class="builder-header">
              <div class="builder-avatar" aria-hidden="true"></div>
              <div>
                <span class="builder-label">Built by</span>
                <strong><a href="https://bollenbach.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-bollenbach" data-umami-event-source="builder-card">Patrick Bollenbach</a></strong>
              </div>
            </div>
            <p class="builder-bio">I make community tools in Vancouver. <a href="mailto:vancouver@bolle.co" data-umami-event="click-contact-email">Get in touch</a>.</p>
            <div class="builder-links">
              <a href="https://runclubs.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-runclubs" data-umami-event-source="builder-card">runclubs.ca</a>
              <span class="builder-link-sep">&middot;</span>
              <a href="https://cuento.app?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-cuento" data-umami-event-source="builder-card">cuento.app</a>
            </div>
          </div>
        </div>
    </div>
  </div>
  <div class="homepage-groups" id="homepage-groups">
    {%- for group in groups %}
    <div class="cat-group">
      <p class="cat-group-heading">{{ group.label | ampEscape | safe }}</p>
      <ul class="cat-group-list">
        {%- for cat in collections.categories %}
        {%- if cat.data.group == group.key %}
        <li><a href="/{{ cat.fileSlug }}/" data-umami-event="click-category" data-umami-event-category="{{ cat.fileSlug }}"><span class="cat-name">{{ cat.data.title }}</span>{% if cat.data.groupCount > 0 %}<span class="cat-count">{{ cat.data.groupCount }}</span>{% endif %}</a></li>
        {%- endif %}
        {%- endfor %}
      </ul>
    </div>
    {%- endfor %}
  </div>
  <div class="homepage-promo">
    <p>📖 I'm also building <a href="https://cuento.app?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-cuento-promo" data-umami-event-source="homepage">Cuento</a> — get matched into a small book club in your neighbourhood. Pick your genres, get placed with 5–6 readers nearby, and meet at a local café. <a href="https://cuento.app?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-cuento-promo-cta" data-umami-event-source="homepage">Check it out&nbsp;&rarr;</a></p>
  </div>
  <div class="homepage-footer">
    Made by <a href="https://bollenbach.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer">Patrick Bollenbach</a> in Vancouver. <span id="homepage-total-views"></span>
  </div>
</main>
</div>
{% include "partials/scripts.njk" %}
</body>
</html>
