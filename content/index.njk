---
layout: false
permalink: /
---
{%- set totalGroups = 0 %}
{%- for cat in collections.categories %}
  {%- set totalGroups = totalGroups + cat.data.groupCount %}
{%- endfor %}
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/head.njk" %}
  <title>Vancouver Community Directory — {{ totalGroups }}+ Groups, Clubs & Meetups (2026)</title>
  <meta name="description" content="{{ site.description }}">
  <meta property="og:title" content="Vancouver Community Directory — Find Your People">
  <meta property="og:description" content="{{ site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}/">
  <meta property="og:image" content="{{ site.url }}/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Vancouver Community Directory — Find Your People">
  <meta name="twitter:description" content="{{ site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/og-image.png">
  <link rel="canonical" href="{{ site.url }}/">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}",
    "description": "{{ site.description }}",
    "areaServed": {
      "@type": "City",
      "name": "Vancouver",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "BC",
        "addressCountry": "CA"
      }
    },
    "publisher": {
      "@type": "Person",
      "name": "Patrick Bollenbach",
      "url": "https://bollenbach.ca"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Community Categories in Vancouver",
    "numberOfItems": {{ collections.categories.length }},
    "itemListElement": [
      {%- for cat in collections.categories %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ cat.data.title }}",
        "url": "{{ site.url }}/{{ cat.fileSlug }}/"{% if cat.data.groupCount %},
        "numberOfItems": {{ cat.data.groupCount }}{% endif %}
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
  </script>
</head>
<body class="homepage">
<a href="#main-content" class="skip-link">Skip to content</a>
<header class="site-header">
  <a href="/" class="logo">Vancouver Community</a>
  <button class="sidebar-toggle" aria-expanded="false" aria-controls="sidebar">Browse</button>
</header>
<div class="main-container">
{% set currentSlug = "" %}
{% include "partials/sidebar.njk" %}
<main class="content content-wide" id="main-content">
  <div class="homepage-hero">
    <div class="homepage-hero-layout">
      <div class="homepage-hero-left">
        <h1 class="homepage-lede">Find your people in Vancouver.</h1>
        <p class="homepage-desc">{{ totalGroups }}+ groups across {{ collections.categories.length }} categories. Run clubs, supper clubs, philosophy circles, maker spaces, and more. Browse, click through, show up.</p>
        <p class="homepage-desc-secondary">Vancouver can feel like a hard city to make friends. This directory is here to help — a community-built list of clubs, meetups, and groups where you can actually meet people. Updated weekly, no account needed.</p>
        <div class="homepage-hero-actions">
          <a href="/submit/" data-umami-event="click-submit-cta" data-umami-event-source="homepage">Add a group</a>
          <span class="homepage-sep">&middot;</span>
          <button type="button" onclick="goRandom()" data-umami-event="click-surprise" data-umami-event-source="homepage">Surprise me</button>
          <span class="homepage-sep">&middot;</span>
          <button type="button" onclick="sharePage('homepage', this)" data-umami-event="click-share" data-umami-event-source="homepage">Tell a friend</button>
        </div>
      </div>
      <div class="homepage-hero-newsletter-card">
        <p class="homepage-newsletter-heading">Get the Vancouver roundup</p>
        <p class="homepage-newsletter-desc">New groups, community picks, and neighbourhood events — weekly.</p>
        <form class="newsletter-form" data-umami-event="newsletter-signup">
          <input type="email" class="newsletter-input" placeholder="your@email.com" required aria-label="Email address">
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </form>
        <span class="newsletter-status"></span>
      </div>
    </div>
  </div>

  {%- if recentGroups.length > 0 %}
  <section class="homepage-section">
    <p class="homepage-section-title">Recently added</p>
    <div class="recent-groups">
      {%- for group in recentGroups %}
      <a href="/{{ group.categorySlug }}/#{{ group.name | slugify }}" class="recent-group" data-umami-event="click-recent-group">
        <span class="recent-group-name">{{ group.name }}</span>
        <span class="recent-group-desc">{{ group.description | truncate(80) }}</span>
        <span class="recent-group-cat">{{ group.categoryTitle }}</span>
      </a>
      {%- endfor %}
    </div>
  </section>
  {%- endif %}

  <section class="homepage-section">
    <p class="homepage-section-title">Popular categories</p>
    <div class="popular-cats">
      {%- set sortedCats = collections.categories | sort(true, false, "data.groupCount") %}
      {%- for cat in sortedCats %}
      {%- if loop.index <= 10 and cat.data.groupCount > 0 %}
      <a href="/{{ cat.fileSlug }}/" class="popular-cat" data-umami-event="click-popular-cat">{{ cat.data.title }} <span>{{ cat.data.groupCount }}</span></a>
      {%- endif %}
      {%- endfor %}
    </div>
  </section>

  <div class="homepage-bottom">
    <div class="builder-card">
      <div class="builder-header">
        <div class="builder-avatar" aria-hidden="true"></div>
        <div>
          <span class="builder-label">Built by</span>
          <strong><a href="https://bollenbach.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-bollenbach" data-umami-event-source="builder-card">Patrick Bollenbach</a></strong>
        </div>
      </div>
      <p class="builder-bio">I make community tools in Vancouver. <a href="mailto:vancouver@bolle.co" data-umami-event="click-contact-email">Get in touch</a>.</p>
      <div class="builder-links">
        <a href="https://runclubs.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-runclubs" data-umami-event-source="builder-card">runclubs.ca</a>
        <span class="builder-link-sep">&middot;</span>
        <a href="https://cuento.app?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-cuento" data-umami-event-source="builder-card">cuento.app</a>
      </div>
    </div>
  </div>
  <div class="homepage-footer">
    <span id="homepage-total-views"></span>
  </div>
</main>
</div>
{% include "partials/scripts.njk" %}
</body>
</html>
