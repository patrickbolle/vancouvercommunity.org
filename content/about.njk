{%- set totalGroups = 0 %}
{%- for cat in collections.categories %}
  {%- set totalGroups = totalGroups + cat.data.groupCount %}
{%- endfor %}
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/head.njk" %}
  <title>About | {{ site.title }}</title>
  <meta name="description" content="Vancouver Community is a free, community-built directory of {{ totalGroups }}+ clubs, meetups, and groups in Vancouver.">
  <meta property="og:title" content="About Vancouver Community">
  <meta property="og:description" content="A free, community-built directory of {{ totalGroups }}+ clubs, meetups, and groups in Vancouver.">
  <meta property="og:type" content="website">
