<nav class="sidebar" id="sidebar">
  <ul>
    <li class="sidebar-logo-item"><a href="/" class="sidebar-logo"><span class="logo-city">Vancouver</span><span class="logo-type">Community</span></a></li>
    {%- for group in groups %}
    <li class="sidebar-group-label">{{ group.label | ampEscape | safe }}</li>
    {%- for cat in collections.categories %}
    {%- if cat.data.group == group.key %}
    <li><a href="/{{ cat.fileSlug }}/"{% if cat.fileSlug == currentSlug %} class="active"{% endif %} data-umami-event="click-sidebar" data-umami-event-category="{{ cat.fileSlug }}"><span class="emoji">{{ cat.data.emoji }}</span> {{ cat.data.title }}{% if cat.data.groupCount > 0 %}<span class="count">{{ cat.data.groupCount }}</span>{% endif %}</a></li>
    {%- endif %}
    {%- endfor %}
    {%- endfor %}
  </ul>
  <div class="sidebar-scroll-hint" id="sidebar-scroll-hint" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
  <div class="sidebar-footer">
    <a href="/submit/" data-umami-event="click-submit-cta" data-umami-event-source="sidebar">Submit a group</a>
    <a href="#" class="surprise-btn" onclick="goRandom(); return false;" data-umami-event="click-surprise" data-umami-event-source="sidebar"><span class="surprise-dice">&#x1F3B2;</span> Surprise me</a>
    <span id="total-views"></span>
    <div class="sidebar-footer-meta">
      Updated {% buildDateHuman %}
      · <a href="https://bollenbach.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-bollenbach" data-umami-event-source="sidebar-footer">Patrick Bollenbach</a>
    </div>
  </div>
</nav>
