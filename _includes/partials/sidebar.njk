<nav class="sidebar" id="sidebar">
  <ul>
    <li class="sidebar-logo-item"><a href="/" class="sidebar-logo"><span class="logo-city">Vancouver<span class="logo-accent">.</span></span><span class="logo-type">Community Directory</span></a></li>
    {%- for group in groups %}
    <li class="sidebar-group-label">{{ group.label | ampEscape | safe }}</li>
    {%- for cat in collections.categories %}
    {%- if cat.data.group == group.key %}
    <li><a href="/{{ cat.fileSlug }}/"{% if cat.fileSlug == currentSlug %} class="active"{% endif %} data-umami-event="click-sidebar" data-umami-event-category="{{ cat.fileSlug }}">{{ cat.data.title }}{% if cat.data.groupCount > 0 %}<span class="count">{{ cat.data.groupCount }}</span>{% endif %}</a></li>
    {%- endif %}
    {%- endfor %}
    {%- endfor %}
  </ul>
  <div class="sidebar-scroll-hint" id="sidebar-scroll-hint" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
  <div class="sidebar-newsletter">
    <p class="sidebar-newsletter-label">Get the roundup</p>
    <form class="sidebar-newsletter-form newsletter-form" data-umami-event="newsletter-signup">
      <input type="email" class="sidebar-newsletter-input newsletter-input" placeholder="your@email.com" required aria-label="Email address">
      <button type="submit" class="sidebar-newsletter-btn newsletter-btn">Join</button>
    </form>
    <span class="newsletter-status sidebar-newsletter-status"></span>
  </div>
  <div class="sidebar-footer">
    <div class="sidebar-footer-actions">
      <a href="/submit/" data-umami-event="click-submit-cta" data-umami-event-source="sidebar">Submit a group</a>
      <span class="sidebar-footer-sep">&middot;</span>
      <button type="button" onclick="goRandom()" data-umami-event="click-surprise" data-umami-event-source="sidebar">Surprise me &rarr;</button>
    </div>
    <div class="sidebar-footer-meta">
      Made by <a href="https://bollenbach.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-bollenbach" data-umami-event-source="sidebar-footer">Patrick Bollenbach</a>
    </div>
  </div>
</nav>
